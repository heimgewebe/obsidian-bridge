#!/usr/bin/env bash
# obsidian-json
# Wrapper that extracts the first valid JSON object {...} or array [...] from noisy output.
# Usage:
#   obsidian-json [args...]   (executes obsidian-clean [args...])
#   <command> | obsidian-json (reads from stdin)

set -euo pipefail

# Find the repository bin directory so we can reliably call obsidian-clean
REPO_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Define the extraction logic
extract_json() {
  local extracted
  extracted=$(awk '
  BEGIN {
    in_json = 0
    depth = 0
  }
  {
    if (!in_json) {
      if ($0 ~ /^[ \t]*[{[]/) {
        in_json = 1
        # Count depth on the first line
        for (i = 1; i <= length($0); i++) {
          c = substr($0, i, 1)
          if (c == "{" || c == "[") depth++
          if (c == "}" || c == "]") depth--
        }
        print $0
        if (depth == 0) exit
      }
    } else {
      for (i = 1; i <= length($0); i++) {
        c = substr($0, i, 1)
        if (c == "{" || c == "[") depth++
        if (c == "}" || c == "]") depth--
      }
      print $0
      if (depth == 0) exit
    }
  }
  ')

  if [ -z "$extracted" ]; then
    echo "Error: No valid JSON object or array found in output." >&2
    exit 1
  fi

  echo "$extracted" | jq -c .
}

if [ "$#" -gt 0 ]; then
  # Wrapper mode: execute obsidian-clean with arguments
  "$REPO_BIN/obsidian-clean" "$@" | extract_json
else
  # Pipe mode: read from stdin
  extract_json
fi
