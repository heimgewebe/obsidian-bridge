#!/usr/bin/env bash
# obsidian-json
# Wrapper that extracts the first valid JSON object {...} or array [...] from noisy output.
# Usage:
#   obsidian-json [args...]   (executes obsidian-clean [args...])
#   <command> | obsidian-json (reads from stdin)

set -euo pipefail

# Find the repository bin directory so we can reliably call obsidian-clean
REPO_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Define the extraction logic
extract_json() {
  # We pipe awk directly into jq.
  # awk exits with 0 if it successfully extracted a JSON object,
  # and exits with 2 if it reached the end without finding anything.
  # We use pipefail so that the exit code of awk is preserved if jq succeeds,
  # or if jq fails we catch it.

  if ! awk '
  BEGIN {
    in_json = 0
    depth = 0
    found = 0
  }
  {
    if (!in_json) {
      if ($0 ~ /^[ \t]*[{[]/) {
        in_json = 1
        found = 1
        # Count depth on the first line
        for (i = 1; i <= length($0); i++) {
          c = substr($0, i, 1)
          if (c == "{" || c == "[") depth++
          if (c == "}" || c == "]") depth--
        }
        print $0
        if (depth == 0) { exit 0 }
      }
    } else {
      for (i = 1; i <= length($0); i++) {
        c = substr($0, i, 1)
        if (c == "{" || c == "[") depth++
        if (c == "}" || c == "]") depth--
      }
      print $0
      if (depth == 0) { exit 0 }
    }
  }
  END {
    if (!found) {
      exit 2
    }
  }
  ' | jq -c .; then
    # If awk exits with 2, we know it didn't find any JSON.
    # If the pipeline fails for other reasons (like jq parse error), it also fails here.
    # But specifically if PIPESTATUS[0] is 2, it means no JSON was found.
    # If PIPESTATUS[1] is non-zero, jq failed to parse the extracted JSON.

    # Capture PIPESTATUS array immediately so it doesn't get overwritten
    local pipe_status=("${PIPESTATUS[@]}")
    local awk_status="${pipe_status[0]:-0}"
    local jq_status="${pipe_status[1]:-0}"

    if [ "$awk_status" -eq 2 ]; then
      echo "Error: No valid JSON object or array found in output." >&2
    elif [ "$jq_status" -ne 0 ]; then
      echo "Error: Extracted JSON but jq failed to parse it." >&2
      echo "Input may contain incomplete JSON or braces inside strings." >&2
    fi
    exit 1
  fi
}

if [ "$#" -gt 0 ]; then
  # Wrapper mode: execute obsidian-clean with arguments
  "$REPO_BIN/obsidian-clean" "$@" | extract_json
else
  # Pipe mode: read from stdin
  extract_json
fi
