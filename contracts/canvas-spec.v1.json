{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanvasSpec.v1",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "source": {
      "type": "object",
      "properties": {
        "artifact_types": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "layout": { "type": "string" },
    "filters": {
      "type": "object",
      "properties": {
        "max_nodes": { "type": "integer" },
        "date_window_days": { "type": "integer" }
      }
    },
    "relations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output": { "type": "string" }
  },
  "required": ["id", "type", "layout", "output"]
}
