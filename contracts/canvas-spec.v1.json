{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanvasSpec.v1",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "source": {
      "type": "object",
      "properties": {
        "artifact_types": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["artifact_types"]
    },
    "layout": { "type": "string" },
    "filters": {
      "type": "object",
      "properties": {
        "max_nodes": { "type": "integer" },
        "max_edges": { "type": "integer", "minimum": 0 },
        "max_depth": { "type": "integer", "minimum": 0 },
        "max_clusters": { "type": "integer", "minimum": 1 },
        "date_window_days": { "type": "integer", "minimum": 0 },
        "calendar_month": { "type": "string", "pattern": "^\\d{4}-(0[1-9]|1[0-2])$" },
        "prioritize_recent": { "type": "boolean" },
        "prioritize_strongest": { "type": "boolean" },
        "prioritized_relations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output": { "type": "string" }
  },
  "required": ["id", "type", "layout", "source", "output"]
}
