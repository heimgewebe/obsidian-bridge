{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanvasSpec.v1",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "source": {
      "type": "object",
      "properties": {
        "artifact_types": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["artifact_types"]
    },
    "layout": { "type": "string" },
    "filters": {
      "type": "object",
      "properties": {
        "max_nodes": { "type": "integer" },
        "max_edges": { "type": "integer", "minimum": 0 },
        "date_window_days": { "type": "integer", "minimum": 0 }
      }
    },
    "relations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output": { "type": "string" }
  },
  "required": ["id", "type", "layout", "source", "output"]
}
