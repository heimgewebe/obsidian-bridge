{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Layout.v1",
  "type": "object",
  "properties": {
    "canvases": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "properties": {
            "nodes": {
              "type": "object",
              "patternProperties": {
                "^.*$": {
                  "type": "object",
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "width": { "type": "number" },
                    "height": { "type": "number" }
                  },
                  "required": ["x", "y", "width", "height"]
                }
              }
            }
          },
          "required": ["nodes"]
        }
      }
    }
  },
  "required": ["canvases"]
}
