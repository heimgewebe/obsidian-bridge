{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Graph.v1",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "title": { "type": "string" },
          "file_path": { "type": "string" },
          "source_repo": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id", "kind", "title", "file_path"]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "relation": { "type": "string" },
          "weight": { "type": "number" }
        },
        "required": ["id", "from", "to", "relation"]
      }
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "nodes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id", "title"]
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" }
        },
        "required": ["id", "title"]
      }
    }
  },
  "required": ["nodes", "edges"]
}
